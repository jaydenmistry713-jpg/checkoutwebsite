# ─── Supabase ───────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ─── Stripe (use TEST keys) ──────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Found in: Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend ──────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_...
# The "from" address (must be a verified domain in Resend)
RESEND_FROM_EMAIL=tickets@yourdomain.com

# ─── App ─────────────────────────────────────────────────────
# Your Netlify site URL (no trailing slash)
SITE_URL=https://your-site.netlify.app
# Business owner email — receives notification on every ticket sale
ADMIN_EMAIL=owner@yourbusiness.com
